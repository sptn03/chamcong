// DBML cho dbdiagram.io — App Chấm Công PostgreSQL
// Cách dùng:
// 1. Mở https://dbdiagram.io
// 2. New Diagram
// 3. Copy toàn bộ file này dán vào editor
// 4. dbdiagram sẽ render ERD trực quan

// =========================================================
// ENUMS
// =========================================================

Enum account_status {
  active
  locked
}

Enum membership_role {
  admin
  employee
}

Enum employee_status {
  active
  locked
  resigned
}

Enum gender_type {
  male
  female
  other
}

Enum device_platform {
  ios
  android
}

Enum device_status {
  pending
  approved
  rejected
  revoked
}

Enum login_request_type {
  new_login
  new_device
}

Enum approval_status {
  pending
  approved
  rejected
}

Enum wifi_match_mode {
  ssid
  ssid_bssid
}

Enum attendance_method {
  gps
  wifi
  gps_wifi
}

Enum shift_assignment_scope {
  company
  branch
  department
  employee
}

Enum punch_type {
  in
  out
}

Enum attendance_source {
  online
  offline
  admin_edit
}

Enum work_status {
  normal
  late
  early
  late_early
  forgot
  absent
}

// =========================================================
// 1. ACCOUNT & COMPANY
// =========================================================

Table accounts {
  id bigint [pk, increment]

  phone varchar(20) [not null, unique, note: 'SĐT đăng nhập']
  email varchar(190) [unique]
  pass varchar(255)

  google_sub varchar(190) [unique]
  apple_sub varchar(190) [unique]

  status account_status [not null, default: 'active']

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Tài khoản đăng nhập. Một account có thể thuộc nhiều công ty.'
}

Table companies {
  id bigint [pk, increment]

  name varchar(190) [not null]
  code varchar(60) [not null, unique]
  tax_id varchar(60)
  timezone varchar(60) [not null, default: 'Asia/Ho_Chi_Minh']

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Công ty.'
}

Table branches {
  id bigint [pk, increment]

  company_id bigint [not null]
  name varchar(190) [not null]
  address varchar(255)

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
  }

  Note: 'Chi nhánh thuộc công ty.'
}

Table departments {
  id bigint [pk, increment]

  company_id bigint [not null]
  branch_id bigint [not null]

  name varchar(190) [not null]

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
    branch_id
  }

  Note: 'Phòng ban/bộ phận thuộc chi nhánh.'
}

Table employees {
  id bigint [pk, increment]

  account_id bigint [not null]
  company_id bigint [not null]
  branch_id bigint [not null]
  department_id bigint [not null]

  employee_code varchar(60) [not null]
  full_name varchar(190) [not null]
  email varchar(190)
  phone varchar(20) [not null]

  birthday date
  gender gender_type
  title varchar(120)

  status employee_status [not null, default: 'active']

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    company_id
    branch_id
    department_id
    (company_id, employee_code) [unique]
  }

  Note: 'Hồ sơ nhân viên trong từng công ty.'
}

Table company_memberships {
  id bigint [pk, increment]

  account_id bigint [not null]
  company_id bigint [not null]
  employee_id bigint

  role membership_role [not null, default: 'employee']

  active_department_id bigint

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    company_id
    employee_id
    (account_id, company_id) [unique]
  }

  Note: 'Quyền chính theo từng công ty. Không dùng accounts.role để phân quyền công ty.'
}

// =========================================================
// 2. DEVICE, SESSION, LOGIN APPROVAL
// =========================================================

Table devices {
  id bigint [pk, increment]

  account_id bigint [not null]

  device_uid varchar(190) [not null]
  device_name varchar(190)
  platform device_platform [not null]
  os_version varchar(60)
  app_version varchar(60)
  push_token varchar(255)

  status device_status [not null, default: 'pending']
  last_login_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    status
    (account_id, device_uid) [unique]
  }

  Note: 'Thiết bị đăng nhập. Thiết bị mới cần Admin duyệt.'
}

Table user_sessions {
  id bigint [pk, increment]

  account_id bigint [not null]
  device_id bigint

  refresh_token_hash varchar(255) [not null]

  ip_address varchar(60)
  user_agent varchar(255)

  expires_at timestamptz [not null]
  revoked_at timestamptz

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    device_id
    expires_at
    revoked_at
  }

  Note: 'Phiên đăng nhập/refresh token.'
}

Table login_approval_requests {
  id bigint [pk, increment]

  account_id bigint [not null]
  employee_id bigint
  device_id bigint [not null]

  request_type login_request_type [not null]
  status approval_status [not null, default: 'pending']

  ip_address varchar(60)
  user_agent varchar(255)

  reviewed_by bigint
  reviewed_at timestamptz
  rejection_reason varchar(255)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    employee_id
    device_id
    status
  }

  Note: 'Yêu cầu Admin xác nhận đăng nhập hoặc thiết bị mới.'
}

// =========================================================
// 3. GPS & WIFI
// =========================================================

Table locations {
  id bigint [pk, increment]

  company_id bigint [not null]
  branch_id bigint [not null]

  name varchar(190) [not null]
  address varchar(255)

  lat numeric(10,7) [not null]
  lng numeric(10,7) [not null]
  radius_m int [not null, default: 80]

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
    branch_id
  }

  Note: 'Danh mục vị trí GPS.'
}

Table location_employee_overrides {
  id bigint [pk, increment]

  location_id bigint [not null]
  employee_id bigint [not null]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    location_id
    employee_id
    (location_id, employee_id) [unique]
  }

  Note: 'Cho phép nhân viên cụ thể được chấm ở vị trí GPS riêng.'
}

Table wifis {
  id bigint [pk, increment]

  company_id bigint [not null]
  branch_id bigint [not null]

  name varchar(190)
  ssid varchar(190) [not null]
  bssid varchar(60)

  match_mode wifi_match_mode [not null, default: 'ssid_bssid']

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
    branch_id
    ssid
  }

  Note: 'Danh mục Wifi dùng để đối chiếu chấm công.'
}

// =========================================================
// 4. SHIFTS
// =========================================================

Table shifts {
  id bigint [pk, increment]

  company_id bigint [not null]

  name varchar(190) [not null]

  start_time time [not null]
  end_time time [not null]

  checkin_from time [not null]
  checkin_to time [not null]

  checkout_from time
  checkout_to time

  weekdays text[] [not null, note: 'mon,tue,wed,thu,fri,sat,sun']

  attendance_method attendance_method [not null]

  late_threshold_min int [not null, default: 0]
  early_threshold_min int [not null, default: 0]

  shifts_per_workday numeric(5,2) [not null, default: 1.00]

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
  }

  Note: 'Cấu hình ca làm.'
}

Table shift_locations {
  id bigint [pk, increment]

  shift_id bigint [not null]
  location_id bigint [not null]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    shift_id
    location_id
    (shift_id, location_id) [unique]
  }

  Note: 'Vị trí GPS được chọn cho ca.'
}

Table shift_wifis {
  id bigint [pk, increment]

  shift_id bigint [not null]
  wifi_id bigint [not null]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    shift_id
    wifi_id
    (shift_id, wifi_id) [unique]
  }

  Note: 'Wifi được chọn cho ca.'
}

Table shift_assignments {
  id bigint [pk, increment]

  shift_id bigint [not null]
  scope_type shift_assignment_scope [not null]

  company_id bigint [not null]
  branch_id bigint
  department_id bigint
  employee_id bigint

  starts_on date
  ends_on date

  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    shift_id
    company_id
    branch_id
    department_id
    employee_id
    scope_type
  }

  Note: 'Gán ca theo công ty, chi nhánh, phòng ban hoặc nhân viên.'
}

// =========================================================
// 5. ATTENDANCE
// =========================================================

Table attendance_records {
  id bigint [pk, increment]

  company_id bigint [not null]
  employee_id bigint [not null]
  shift_id bigint [not null]

  work_date date [not null, note: 'Nếu ca qua đêm thì đây là ngày bắt đầu ca.']

  checkin_at timestamptz
  checkout_at timestamptz

  source attendance_source [not null, default: 'online']

  approval_status approval_status [not null, default: 'approved']
  work_status work_status [not null, default: 'normal']

  late_min int [not null, default: 0]
  early_min int [not null, default: 0]

  work_credit numeric(6,2) [not null, default: 0.00]

  approved_by bigint
  approved_at timestamptz
  rejection_reason varchar(255)

  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    company_id
    employee_id
    shift_id
    work_date
    approval_status
    work_status
    (employee_id, shift_id, work_date) [unique]
  }

  Note: 'Bản ghi công tổng theo nhân viên-ca-ngày.'
}

Table attendance_evidences {
  id bigint [pk, increment]

  attendance_record_id bigint [not null]

  punch_type punch_type [not null]

  device_id bigint

  client_time timestamptz [not null, note: 'Thời gian trên máy nhân viên.']
  server_time timestamptz [not null, default: `now()`, note: 'Thời gian server nhận request.']

  lat numeric(10,7)
  lng numeric(10,7)
  accuracy_m numeric(8,2)

  wifi_ssid varchar(190)
  wifi_bssid varchar(60)

  photo varchar(255)
  photo_hash varchar(255)

  note varchar(255)

  gps_valid boolean [not null, default: false]
  wifi_valid boolean [not null, default: false]

  distance_m numeric(10,2)
  matched_location_id bigint
  matched_wifi_id bigint
  validation_error varchar(255)

  created_at timestamptz [not null, default: `now()`]

  indexes {
    attendance_record_id
    device_id
    punch_type
    matched_location_id
    matched_wifi_id
  }

  Note: 'Bằng chứng từng lần chấm: GPS, Wifi, ảnh, thiết bị.'
}

Table attendance_edit_logs {
  id bigint [pk, increment]

  attendance_record_id bigint [not null]
  edited_by bigint [not null]

  before_json jsonb
  after_json jsonb [not null]
  reason varchar(255) [not null]

  created_at timestamptz [not null, default: `now()`]

  indexes {
    attendance_record_id
    edited_by
  }

  Note: 'Log riêng cho việc Admin sửa bản ghi chấm công.'
}

// =========================================================
// 6. NOTIFICATIONS
// =========================================================

Table notifications {
  id bigint [pk, increment]

  company_id bigint
  account_id bigint [not null]

  type varchar(60) [not null]
  title varchar(190) [not null]
  body text
  data_json jsonb

  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    account_id
    company_id
    read_at
    created_at
  }

  Note: 'Thông báo cho nhân viên/admin.'
}



// =========================================================
// RELATIONSHIPS
// =========================================================

// Company structure
Ref: branches.company_id > companies.id
Ref: departments.company_id > companies.id
Ref: departments.branch_id > branches.id

// Account, employee, membership
Ref: employees.account_id > accounts.id
Ref: employees.company_id > companies.id
Ref: employees.branch_id > branches.id
Ref: employees.department_id > departments.id

Ref: company_memberships.account_id > accounts.id
Ref: company_memberships.company_id > companies.id
Ref: company_memberships.employee_id > employees.id
Ref: company_memberships.active_department_id > departments.id

// Devices, sessions, login approval
Ref: devices.account_id > accounts.id

Ref: user_sessions.account_id > accounts.id
Ref: user_sessions.device_id > devices.id

Ref: login_approval_requests.account_id > accounts.id
Ref: login_approval_requests.employee_id > employees.id
Ref: login_approval_requests.device_id > devices.id
Ref: login_approval_requests.reviewed_by > accounts.id

// GPS
Ref: locations.company_id > companies.id
Ref: locations.branch_id > branches.id

Ref: location_employee_overrides.location_id > locations.id [delete: cascade]
Ref: location_employee_overrides.employee_id > employees.id

// Wifi
Ref: wifis.company_id > companies.id
Ref: wifis.branch_id > branches.id

// Shifts
Ref: shifts.company_id > companies.id

Ref: shift_locations.shift_id > shifts.id [delete: cascade]
Ref: shift_locations.location_id > locations.id

Ref: shift_wifis.shift_id > shifts.id [delete: cascade]
Ref: shift_wifis.wifi_id > wifis.id

Ref: shift_assignments.shift_id > shifts.id
Ref: shift_assignments.company_id > companies.id
Ref: shift_assignments.branch_id > branches.id
Ref: shift_assignments.department_id > departments.id
Ref: shift_assignments.employee_id > employees.id

// Attendance
Ref: attendance_records.company_id > companies.id
Ref: attendance_records.employee_id > employees.id
Ref: attendance_records.shift_id > shifts.id
Ref: attendance_records.approved_by > accounts.id

Ref: attendance_evidences.attendance_record_id > attendance_records.id [delete: cascade]
Ref: attendance_evidences.device_id > devices.id
Ref: attendance_evidences.matched_location_id > locations.id
Ref: attendance_evidences.matched_wifi_id > wifis.id

Ref: attendance_edit_logs.attendance_record_id > attendance_records.id [delete: cascade]
Ref: attendance_edit_logs.edited_by > accounts.id

// Notifications
Ref: notifications.company_id > companies.id
Ref: notifications.account_id > accounts.id